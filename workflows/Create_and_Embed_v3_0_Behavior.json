    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n  const obj = item.json;\n\n  // Validate fields\n  const hasBehavior = !!obj.behavior;\n  const hasContext = !!obj.context;\n  const hasText = !!obj.text;\n  const hasKeywords = Array.isArray(obj.keywords);\n\n  // Validate Keywords \n  const keywordCount = hasKeywords ? obj.keywords.length : 0;\n\n  // 🔍 Simple classification check\n  const textLower = (obj.text || \"\").toLowerCase();\n\n  const inferredType =\n    textLower.includes(\"login\") ? \"authentication\" :\n    textLower.includes(\"connection\") ? \"network\" :\n    textLower.includes(\"process\") ? \"process\" :\n    \"unknown\";\n\n  output.push({\n    json: {\n      technique_id: obj.technique_id || \"MISSING\",\n\n      behavior: obj.behavior || \"MISSING\",\n      context: obj.context || \"MISSING\",\n\n      // Validate Embedding \n      text_preview: (obj.text || \"\").substring(0, 120),\n      text_length: (obj.text || \"\").length,\n\n      // Validate Metadata \n      keywords: obj.keywords || [],\n      keyword_count: keywordCount,\n\n      // Validation flags\n      valid_behavior: hasBehavior,\n      valid_context: hasContext,\n      valid_text: hasText,\n      valid_keywords: hasKeywords,\n\n      inferred_type: inferredType,\n\n      // Identify bad entries\n      issues: [\n        !hasBehavior ? \"Missing behavior\" : null,\n        !hasContext ? \"Missing context\" : null,\n        !hasText ? \"Missing text\" : null,\n        !hasKeywords ? \"Missing keywords\" : null,\n        keywordCount === 0 ? \"No keywords extracted\" : null\n      ].filter(Boolean)\n    }\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        832
      ],
      "id": "663f9be5-9c89-444b-b867-50281e612589",
      "name": "Debug"
    },
    {
      "parameters": {
        "jsCode": "const chunks = [];\n\nconst data = items[0].json.data;\n\nif (!Array.isArray(data)) {\n  throw new Error(\"Expected an array of behavior patterns at items[0].json.data\");\n}\n\n// 🔥 Add helper function HERE (top of script)\nfunction extractKeywords(obj) {\n  const text = (obj.behavior + \" \" + obj.context).toLowerCase();\n\n  const keywords = [];\n\n  if (text.includes(\"login\")) keywords.push(\"login\");\n  if (text.includes(\"failed\")) keywords.push(\"failure\");\n  if (text.includes(\"ssh\")) keywords.push(\"ssh\");\n  if (text.includes(\"rdp\")) keywords.push(\"rdp\");\n  if (text.includes(\"dns\")) keywords.push(\"dns\");\n  if (text.includes(\"http\")) keywords.push(\"http\");\n  if (text.includes(\"powershell\")) keywords.push(\"powershell\");\n\n  return keywords;\n}\n\nfor (const obj of data) {\n\n  const text = `\n${obj.behavior}. ${obj.context}. Technique ${obj.technique_id}.\n`.replace(/\\s+/g, \" \").trim();\n\n  chunks.push({\n    json: {\n      technique_id: obj.technique_id || \"\",\n      behavior: obj.behavior || \"\",\n      context: obj.context || \"\",\n      text: text,\n      keywords: extractKeywords(obj)\n    }\n  });\n}\n\nreturn chunks;"
      },
