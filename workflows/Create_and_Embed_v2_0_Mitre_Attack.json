    {
      "parameters": {
        "jsCode": "const chunks = [];\n\nfor (const obj of items[0].json.objects) {\n  if (obj.type !== \"attack-pattern\") continue;\n\n  const attackId =\n    obj.external_references?.find(r => r.source_name === \"mitre-attack\")?.external_id\n    || obj.id;\n\n  const tactic = (obj.kill_chain_phases || [])\n    .filter(k => k.kill_chain_name === \"mitre-attack\")\n    .map(k => k.phase_name);\n\n  chunks.push({\n    json: {\n      attack_id: attackId,\n      name: obj.name,\n      tactic: tactic,\n      platforms: obj['x_mitre_platforms'] || [],\n      data_sources: obj['x_mitre_data_sources'] || [],\n      content: obj.description || \"\"\n    }\n  });\n}\n\nreturn chunks;"
      },
